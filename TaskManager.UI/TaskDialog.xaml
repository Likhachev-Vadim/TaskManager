<Window x:Class="TaskManager.UI.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="360" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
        <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" VerticalAlignment="Center"/>
        <TextBox x:Name="DescBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Приоритет:" VerticalAlignment="Center"/>
        <ComboBox x:Name="PriorityBox" Grid.Row="2" Grid.Column="1" Margin="0,4">
            <ComboBoxItem Content="Низкий"/>
            <ComboBoxItem Content="Средний" IsSelected="True"/>
            <ComboBoxItem Content="Высокий"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" VerticalAlignment="Center"/>
        <ComboBox x:Name="StatusBox" Grid.Row="3" Grid.Column="1" Margin="0,4">
            <ComboBoxItem Content="Новая" IsSelected="True"/>
            <ComboBoxItem Content="В процессе"/>
            <ComboBoxItem Content="Завершена"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Срок:" VerticalAlignment="Center"/>
        <DatePicker x:Name="DuePicker" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Важная:" VerticalAlignment="Center"/>
        <CheckBox x:Name="ImportantBox" Grid.Row="5" Grid.Column="1" Margin="0,4" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Сохранить" Width="80" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Отмена" Width="70" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>