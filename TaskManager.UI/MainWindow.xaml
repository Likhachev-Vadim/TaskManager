<Window x:Class="TaskManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер задач" Height="600" Width="900"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox" Width="200" Margin="0,0,8,0"
                     TextChanged="SearchBox_TextChanged"/>
            <ComboBox x:Name="FilterCombo" Width="130" SelectionChanged="FilterCombo_SelectionChanged">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="В процессе"/>
                <ComboBoxItem Content="Завершена"/>
            </ComboBox>
            <ComboBox x:Name="SortCombo" Width="160" Margin="8,0,0,0" SelectionChanged="SortCombo_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По приоритету"/>
                <ComboBoxItem Content="По дате"/>
            </ComboBox>
        </StackPanel>

        <TextBlock x:Name="StatsText" Grid.Row="1" Margin="0,0,0,8" Foreground="Gray"/>

        <ListView x:Name="TaskList" Grid.Row="2" SelectionChanged="TaskList_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="!" Width="25"
                        DisplayMemberBinding="{Binding ImportantMark}"/>
                    <GridViewColumn Header="Название" Width="180"
                        DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Приоритет" Width="90"
                        DisplayMemberBinding="{Binding PriorityDisplay}"/>
                    <GridViewColumn Header="Статус" Width="100"
                        DisplayMemberBinding="{Binding StatusDisplay}"/>
                    <GridViewColumn Header="Срок" Width="100"
                        DisplayMemberBinding="{Binding DueDateDisplay}"/>
                    <GridViewColumn Header="Описание" Width="220"
                        DisplayMemberBinding="{Binding Description}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Добавить" Width="90" Margin="0,0,6,0" Click="AddBtn_Click"/>
            <Button Content="Редактировать" Width="110" Margin="0,0,6,0" Click="EditBtn_Click"/>
            <Button Content="Удалить" Width="80" Click="DeleteBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>